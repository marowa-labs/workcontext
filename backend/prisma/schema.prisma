// AI Action System - Track and manage AI-executed actions
model AIAction {
  id              String    @id @default(uuid())
  user_id         String
  action_type     String // "create_workspace", "create_project", "create_task", "edit_project", "delete_item", "invite_member", etc.
  action_category String // "create", "read", "update", "delete", "manage"
  status          String    @default("pending") // "pending", "confirmed", "executing", "completed", "failed", "cancelled"
  user_intent     String // The original user message/request
  parsed_params   Json? // AI-parsed parameters from the intent
  target_entity   String? // "workspace", "project", "task", "user", etc.
  target_id       String? // ID of the affected entity
  confirmation_required Boolean @default(true)
  confirmed_at    DateTime?
  confirmed_by    String? // user_id who confirmed
  executed_at     DateTime?
  completed_at    DateTime?
  failed_at       DateTime?
  error_message   String?
  result_data     Json? // Result of the action execution
  rollback_data   Json? // Data needed to rollback the action
  is_rolled_back  Boolean   @default(false)
  rolled_back_at  DateTime?
  execution_duration_ms Int? // Time taken to execute
  ai_model_used   String? // Which AI model processed this action
  tokens_used     Int?
  cost_estimate   Float?
  page_context    String? // Which page the user was on when making the request
  session_id      String? // AI chat session ID
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  user            User      @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([action_type])
  @@index([status])
  @@index([target_entity])
  @@index([target_id])
  @@index([created_at])
  @@index([session_id])
}

