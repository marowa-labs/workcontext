# Frontend Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local or .env.backup files to git

# Google API (for search features)
NEXT_PUBLIC_GOOGLE_API_KEY=your_google_api_key_here
NEXT_PUBLIC_GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Backend API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SIGNUP_SURVEY_DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Application Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Hocuspocus WebSocket Configuration
NEXT_PUBLIC_HOCUSPOCUS_SERVER_URL=ws://localhost:9081

# Citation System Configuration
NEXT_PUBLIC_CROSSREF_API_URL=https://api.crossref.org

# Unsplash API Configuration
NEXT_PUBLIC_UNSPLASH_API_URL=https://api.unsplash.com
NEXT_PUBLIC_UNSPLASH_REDIRECT_URL=urn:ietf:wg:oauth:2.0:oob
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
NEXT_PUBLIC_UNSPLASH_SECRET_KEY=your_unsplash_secret_key_here
NEXT_PUBLIC_UNSPLASH_APPLICATION_ID=your_app_id_here

# AI Service Configuration
NEXT_PUBLIC_AI_ENABLED=true

# Feature flags
NEXT_PUBLIC_ENABLE_HTTP_SAVES=true
