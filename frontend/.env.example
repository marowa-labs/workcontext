# Frontend Environment Variables

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Collaboration configuration
NEXT_PUBLIC_COLLABORATION_API_URL=wss://your-backend-domain.com/hocuspocus
NEXT_PUBLIC_COLLAB_URL=wss://your-backend-domain.com/hocuspocus

# Backend API Configuration
NEXT_PUBLIC_API_URL=your-backend-api-url.com

# Notification WebSocket Configuration
# WebSocket servers share the main HTTP server via path-based routing
# Just set the backend host - no port needed
NEXT_PUBLIC_NOTIFICATION_WS_HOST=your-backend-domain.com

# Application Settings
NEXT_PUBLIC_APP_URL=your-app-url.com
BACKEND_URL=your-backend-url.com

# Hocuspocus WebSocket Configuration
NEXT_PUBLIC_HOCUSPOCUS_SERVER_URL=wss://your-backend-domain.com/hocuspocus

# Citation System Configuration
NEXT_PUBLIC_CROSSREF_API_URL=your-crossref-api-url.com

# Unsplash API Configuration
NEXT_PUBLIC_UNSPLASH_API_URL=your-unsplash-api-url.com
NEXT_PUBLIC_UNSPLASH_REDIRECT_URL=your-app-url.com
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=your-access-key
NEXT_PUBLIC_UNSPLASH_SECRET_KEY=your-secret-key
NEXT_PUBLIC_UNSPLASH_APPLICATION_ID=your-application-id

# AI Service Configuration
# Note: Frontend should not contain actual API keys for security reasons
# These are just placeholders or public keys for client-side services
NEXT_PUBLIC_AI_ENABLED=true

# Phase 2: Feature flag to toggle save modes (added during dual-save fix implementation)
# Set to "false" to use Hocuspocus-only mode (recommended - eliminates dual-save conflicts)
# Set to "true" to use dual-save mode (HTTP + Hocuspocus, current default for safety)
# After testing, change to "false" for production
NEXT_PUBLIC_ENABLE_HTTP_SAVES=true